# =============================================================================
# TAKNET-PS Aggregator v1.0.299 — Environment Configuration
# =============================================================================
# Copy this file to .env and edit values as needed.
# =============================================================================

# -- Web Interface -----------------------------------------------------------
WEB_PORT=80
# Feeder tunnel: dashboard proxies /feeder/<feeder_id>/ via TUNNEL_SERVICE_URL (default http://tunnel:5001 in compose)
# Secret key for session cookies — change this to a random string in production
SECRET_KEY=change-me-to-a-random-string

# -- Aggregator Ports --------------------------------------------------------
# Feeders send Beast reduce plus on 30004, MLAT on 30105, pick up results on 39001
BEAST_PORT=30004                    # Beast reduce plus input from feeders
# Beast-proxy: seconds without receiving data from a feeder before treating it offline (default 120)
# INACTIVE_FEEDER_TIMEOUT=120
SBS_PORT=30003                      # SBS BaseStation output
MLAT_IN_PORT=30105                  # MLAT input from feeders
MLAT_RESULTS_PORT=39001             # MLAT results back to feeders

# -- Site Information --------------------------------------------------------
SITE_NAME="TAKNET-PS Aggregator"
SITE_LAT=33.8753
SITE_LON=-117.5664
SITE_ALT_FT=738
TZ=America/Los_Angeles

# -- Data Paths --------------------------------------------------------------
INSTALL_DIR=/opt/taknet-aggregator
DATA_DIR=/var/lib/taknet-aggregator

# -- VPN Configuration -------------------------------------------------------
# Tailscale — runs on the host, socket is mounted into containers
TAILSCALE_ENABLED=true
TAILSCALE_API_SOCKET=/var/run/tailscale/tailscaled.sock
TAILSCALE_CIDR=100.64.0.0/10

# NetBird (future feeder VPN)
NETBIRD_ENABLED=false
NETBIRD_API_URL=http://localhost:33073
NETBIRD_API_TOKEN=
NETBIRD_CIDR=100.64.0.0/10

# NetBird client — set NB_SETUP_KEY to persist enrollment through updates
# (Enrollment can also be done via the VPN page in the dashboard)
NB_SETUP_KEY=

# -- GeoIP -------------------------------------------------------------------
# Auto-downloaded db-ip.com City Lite database (no registration required)
# Rebuild beast-proxy to refresh: taknet-agg rebuild
GEOIP_ENABLED=true

# -- ADSBHub.org --------------------------------------------------------------
# Feed SBS to ADSBHub (port 5001) and/or receive aggregated SBS (port 5002).
# See ADSBHUB_INTEGRATION.md and ADSBHub Connection Guide.
# Required for feed: get Station dynamic IP key (CLIENTKEY) from ADSBHub Settings → New Station.
# If CLIENTKEY contains $ or other special chars, wrap in single quotes in .env: ADSBHUB_CLIENT_KEY='key$$here'
ADSBHUB_FEED_ENABLED=false
ADSBHUB_CLIENT_KEY=
ADSBHUB_FEED_HOST=data.adsbhub.org
ADSBHUB_FEED_PORT=5001
ADSBHUB_RECEIVE_ENABLED=false
ADSBHUB_HOST=data.adsbhub.org
ADSBHUB_PORT=5002
# Shared volume path inside feeder/merger containers for feed.json and receive.json (dashboard reads via ADSBHUB_STATUS_PATH).
# ADSBHUB_STATUS_DIR=/status
# Merger: drop aircraft not seen in this many seconds (default 10). Map/API get no stale data.
# MERGER_STALE_SECONDS=10
#
# Dashboard/CoT/JSON stream: where to fetch aircraft.json. Use the merger when ADSBHub receive
# is enabled so the feed has "source" (adsbhub vs direct) and "Include Network ADSB" filter works.
# In Docker the dashboard gets this from compose; override in .env if needed (e.g. different host/port).
# AIRCRAFT_JSON_URL=http://aircraft-merger:8090/data/aircraft.json
#
# CoT push: interval in seconds between cycles (default 2). Lower = faster marker updates; cycle must finish before next run.
# COT_PUSH_INTERVAL_SECONDS=2

# -- Transactional Email (Resend) -------------------------------------------
# Used for admin registration alerts, password reset, and welcome email when a pending user is approved.
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL="noreply@notify.tak-solutions.com"
RESEND_ADMIN_EMAILS=
